port: 7890
socks-port: 7891
mixed-port: 7892
allow-lan: true
mode: rule
log-level: info
external-controller: 0.0.0.0:9090

proxies:
  # =========================================================================
  # 1. 静态住宅 IP 落地节点 (Your Static Residential Exit IP)
  # Please replace the fields below with your purchased residential IP details.
  # =========================================================================
  - name: "静态IP代理"
    type: socks5
    server: 192.0.2.1
    port: 443
    username: "your_username"
    password: "your_password"
    dialer-proxy: "Transit-Auto-Select"

proxy-providers:
  # =========================================================================
  # 2. 中继订阅源 (Your Transit Node Subscription URL)
  # Replace the URL below with your actual Clash subscription link.
  # =========================================================================
  jssrgssr:
    type: http
    url: "https://your-subscription-link-here.com/link/xxxx?clash=1"
    interval: 86400
    path: ./subscription.yaml
    health-check:
      enable: true
      interval: 600
      url: http://www.gstatic.com/generate_204

proxy-groups:
  # =========================================================================
  # 中继自动选择组 (Transit Proxy Group - Auto selects the fastest node from subscription)
  # =========================================================================
  - name: "Transit-Auto-Select"
    type: url-test
    use:
      - jssrgssr
    filter: "奥地利" # 可选：用正则表达式过滤订阅节点区域（如"奥地利"），使其与您的落地IP地理位置邻近（当前落地为荷兰），从而避免跨国绕路延迟
    url: "http://www.gstatic.com/generate_204"
    interval: 300
    tolerance: 50

  # =========================================================================
  # 链式代理 (Chain Proxy / Relay Group)
  # Traffic flows from your NAS -> Transit-Auto-Select -> Residential-Exit -> AI API
  # =========================================================================
  - name: "AI-Relay-Group"
    type: select
    proxies:
      - "静态IP代理"

  # =========================================================================
  # 默认代理组 (Default Proxy Group for General Downloads like GitHub / Fonts)
  # Routes directly through your fast transit node, saving residential IP quota!
  # =========================================================================
  - name: "Default-Group"
    type: select
    proxies:
      - "Transit-Auto-Select"
      - "DIRECT"

rules:
  # Route AI platforms through the pure Residential exit
  - DOMAIN-SUFFIX,openai.com,AI-Relay-Group
  - DOMAIN-SUFFIX,chatgpt.com,AI-Relay-Group
  - DOMAIN-SUFFIX,oaistatic.com,AI-Relay-Group
  - DOMAIN-SUFFIX,oaiusercontent.com,AI-Relay-Group
  - DOMAIN-SUFFIX,anthropic.com,AI-Relay-Group
  - DOMAIN-SUFFIX,googleapis.com,AI-Relay-Group
  - DOMAIN-SUFFIX,google.com,AI-Relay-Group
  - DOMAIN-SUFFIX,google,AI-Relay-Group
  - DOMAIN-SUFFIX,run.app,AI-Relay-Group

  # Route GitHub and Google Fonts through the high-speed transit node directly
  - DOMAIN-KEYWORD,github,Default-Group
  - DOMAIN-SUFFIX,githubusercontent.com,Default-Group
  - DOMAIN-SUFFIX,gstatic.com,Default-Group
  - DOMAIN-SUFFIX,googlefonts.com,Default-Group
  
  # Default direct access for local NAS services
  - MATCH,DIRECT
